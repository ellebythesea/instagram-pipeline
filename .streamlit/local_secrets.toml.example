# Bootstrap Google auth for Secret Manager access.
GOOGLE_CREDENTIALS_BASE64 = "base64-encoded-service-account-json"

# Optional if the service account belongs to a different project than the
# Secret Manager project, or if you want to override the inferred project id.
SECRET_MANAGER_PROJECT_ID = "vioo-instagram-pipeline"

# Optional direct fallbacks if Secret Manager is unavailable.
# OPENAI_API_KEY = "sk-..."
# APIFY_API_TOKEN = "..."
# GOOGLE_SHEET_ID = "..."
# GOOGLE_WORKSHEET_NAME = "..."
# GOOGLE_DRIVE_FOLDER_ID = "..."
# GOOGLE_OAUTH_CLIENT_JSON = '''{"installed":{...}}'''
# GOOGLE_OAUTH_TOKEN_JSON = '''{"token":"...","refresh_token":"..."}'''
# APP_PASSWORD = "..."
